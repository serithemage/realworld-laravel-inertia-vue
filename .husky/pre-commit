#!/usr/bin/env sh

# Skip checks for documentation-only changes
CHANGED_FILES=$(git diff --cached --name-only)
NON_DOC_FILES=$(echo "$CHANGED_FILES" | grep -vE '\.(md|txt|rst)$' | grep -vE '^docs/' || true)

if [ -z "$NON_DOC_FILES" ]; then
    echo "Documentation-only changes detected. Skipping pre-commit checks."
    exit 0
fi

npx lint-staged
